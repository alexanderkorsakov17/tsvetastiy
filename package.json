{
  "name": "цветастый---relax-&-shop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx ./api/index.ts",
    "build": "vite build && esbuild ./api/index.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:vite --external:express --external:axios --external:cookie-session",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@auth/express": "^0.12.1",
    "@google/genai": "^1.40.0",
    "@pbe/react-yandex-maps": "^1.2.5",
    "axios": "^1.14.0",
    "cookie-session": "^2.1.1",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^6.4.1"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
